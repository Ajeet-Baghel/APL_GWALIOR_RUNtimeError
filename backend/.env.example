PORT=5001
FRONTEND_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cricagent

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# WeatherAPI.com: https://www.weatherapi.com/docs/
WEATHER_API_KEY=your_weatherapi_key
WEATHER_API_URL=https://api.weatherapi.com/v1/current.json
# OpenWeather alternative: https://api.openweathermap.org/data/2.5/weather

# CricAPI: adjust the URL if your cricket-data provider differs.
CRICKET_API_KEY=your_cricket_api_key
CRICKET_API_URL=https://api.cricapi.com/v1/currentMatches
